<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.springbootstudy.bbs.mapper.ChatRoomMapper">

    <!-- 공통 매핑 -->
    <resultMap id="ChatRoomResultMap" type="ChatRoomVO">
        <id     property="chatroomIdx" column="chatroom_idx"/>
        <result property="auctionIdx"  column="auction_idx"/>
        <result property="buyerIdx"    column="buyer_idx"/>
        <result property="bidderIdx"   column="bidder_idx"/>
        <result property="createdAt"   column="created_at"/>
    </resultMap>

    <!-- PK로 방 한 개 조회 -->
    <select id="findByChatIdx" parameterType="long"
            resultMap="ChatRoomResultMap">
        SELECT
            chatroom_idx,
            auction_idx,
            buyer_idx,
            bidder_idx,
            created_at
        FROM chatroom
        WHERE chatroom_idx = #{chatroomIdx}
    </select>

    <!-- 경매 + buyer + bidder 조합으로 방 조회 -->
    <select id="findByAuctionAndMembers"
            parameterType="map"
            resultMap="ChatRoomResultMap">
        SELECT
            chatroom_idx,
            auction_idx,
            buyer_idx,
            bidder_idx,
            created_at
        FROM chatroom
        WHERE auction_idx = #{auctionIdx}
          AND buyer_idx   = #{buyerIdx}
          AND bidder_idx  = #{bidderIdx}
    </select>

    <!-- 방 생성 -->
    <insert id="insertChatRoom" parameterType="ChatRoomVO"
            useGeneratedKeys="true" keyProperty="chatroomIdx">
        INSERT INTO chatroom (
            auction_idx,
            buyer_idx,
            bidder_idx,
            created_at
        ) VALUES (
            #{auctionIdx},
            #{buyerIdx},
            #{bidderIdx},
            NOW()
        )
    </insert>

    <!-- 내가 참여한 모든 채팅방 목록 조회 (buyer 또는 bidder) -->
    <select id="findByMember" parameterType="long"
            resultMap="ChatRoomResultMap">
        SELECT
            chatroom_idx,
            auction_idx,
            buyer_idx,
            bidder_idx,
            created_at
        FROM chatroom
        WHERE buyer_idx  = #{memIdx}
           OR bidder_idx = #{memIdx}
        ORDER BY created_at DESC
    </select>

</mapper>